# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Embeddings — OpenAI optional, uses LLM provider if empty
OPENAI_API_KEY=
EMBEDDING_MODEL=moonshot-v1-128k-embedding-query

# LLM (required) — Moonshot Kimi K2.5 via OpenAI-compatible API
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_API_KEY=your-moonshot-api-key
LLM_MODEL=kimi-k2.5

# Deepgram STT (required)
DEEPGRAM_API_KEY=your-deepgram-key
NEXT_PUBLIC_DEEPGRAM_API_KEY=your-deepgram-key

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
