# =============================================
# Pretive — Environment Variables
# =============================================

# ----- Supabase (required) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Embeddings (optional — falls back to LLM provider) -----
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-ada-002

# ----- LLM (required) — OpenAI-compatible endpoint -----
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=kimi-k2.5

# ----- Deepgram Speech-to-Text (required) -----
DEEPGRAM_API_KEY=your-deepgram-key
NEXT_PUBLIC_DEEPGRAM_API_KEY=your-deepgram-key

# ----- App / Backend (required) -----
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----- CORS (optional — comma-separated origins) -----
ALLOWED_ORIGINS=http://localhost:3000
