---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="PRETIVE — Financial Projections" description="PRETIVE financial projections, unit economics, and investment details for investors." noindex={true}>

  <Nav activePage="investors" />

  <!-- Main Content -->
  <main style="max-width: 1200px; margin: 0 auto; padding: 120px 24px 80px;">

    <!-- Breadcrumb -->
    <div class="reveal" style="margin-bottom: 40px;">
      <a href="/investors" class="hoverable" style="font-size: 13px; color: rgba(0,0,0,0.35); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
        <span>&larr;</span> Back to Investors
      </a>
    </div>

    <!-- Hero -->
    <section class="reveal" style="margin-bottom: 72px;">
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
        <span class="stamp">Investor Confidential</span>
      </div>
      <h1 class="serif" style="font-size: clamp(42px, 6vw, 72px); line-height: 1.05; letter-spacing: -2px; margin-bottom: 20px;">
        Financial Projections
      </h1>
      <p style="font-size: 18px; color: rgba(0,0,0,0.4); max-width: 640px; line-height: 1.6;">
        A transparent breakdown of our pricing model, unit economics, revenue trajectory, and investment requirements through the first three years of operation.
      </p>
    </section>

    <!-- Section 1: Pricing Model -->
    <section class="reveal" style="margin-bottom: 72px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 32px;">
        <span class="mono" style="font-size: 11px; color: rgba(0,0,0,0.25); font-weight: 600;">01</span>
        <h2 class="serif" style="font-size: 32px; letter-spacing: -1px;">Pricing Model</h2>
      </div>

      <p style="font-size: 13px; color: rgba(0,0,0,0.3); max-width: 560px; line-height: 1.6; margin-bottom: 32px; font-style: italic;">
        Each plan includes a fair-use allowance of live session hours, document storage, and AI processing. Overages are billed per unit so customers pay proportionally for what they use &mdash; and our margins stay healthy as usage scales.
      </p>

      <div class="pricing-grid">
        <!-- Pro -->
        <div class="paper" style="border-radius: 20px; padding: 32px; position: relative;">
          <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px;">Individual</span>
          <h3 class="serif" style="font-size: 28px; margin: 8px 0 4px;">Pro</h3>
          <div style="display: flex; align-items: baseline; gap: 4px; margin-bottom: 12px;">
            <span style="font-size: 36px; font-weight: 800; letter-spacing: -1px;">&euro;19</span>
            <span style="font-size: 14px; color: rgba(0,0,0,0.3);">/mo</span>
          </div>
          <p style="font-size: 14px; color: rgba(0,0,0,0.4); line-height: 1.6; margin-bottom: 16px;">
            Independent trainers, expert speakers, and webinar producers who need an AI copilot for their live sessions.
          </p>
          <div style="border-top: 1px solid rgba(0,0,0,0.06); padding-top: 12px; display: flex; flex-direction: column; gap: 6px;">
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; 10 live hours / mo</span>
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; 2 GB document storage</span>
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; 50 AI card generations / session</span>
          </div>
        </div>

        <!-- Team -->
        <div class="paper" style="border-radius: 20px; padding: 32px; position: relative; border-color: var(--red);">
          <div style="position: absolute; top: -10px; right: 20px; background: var(--red); color: white; font-size: 10px; font-weight: 700; padding: 4px 12px; border-radius: 20px; letter-spacing: 0.5px;">MOST POPULAR</div>
          <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px;">Collaborative</span>
          <h3 class="serif" style="font-size: 28px; margin: 8px 0 4px;">Team</h3>
          <div style="display: flex; align-items: baseline; gap: 4px; margin-bottom: 12px;">
            <span style="font-size: 36px; font-weight: 800; letter-spacing: -1px;">&euro;24</span>
            <span style="font-size: 14px; color: rgba(0,0,0,0.3);">/seat/mo</span>
          </div>
          <p style="font-size: 14px; color: rgba(0,0,0,0.4); line-height: 1.6; margin-bottom: 16px;">
            Academies, institutions, bootcamps, and small teams collaborating on live educational content.
          </p>
          <div style="border-top: 1px solid rgba(0,0,0,0.06); padding-top: 12px; display: flex; flex-direction: column; gap: 6px;">
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; 20 live hours / seat / mo</span>
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; 10 GB shared storage</span>
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; 100 AI card generations / session</span>
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; Team analytics dashboard</span>
          </div>
        </div>

        <!-- Enterprise -->
        <div class="paper" style="border-radius: 20px; padding: 32px;">
          <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px;">Custom</span>
          <h3 class="serif" style="font-size: 28px; margin: 8px 0 4px;">Enterprise</h3>
          <div style="display: flex; align-items: baseline; gap: 4px; margin-bottom: 12px;">
            <span style="font-size: 36px; font-weight: 800; letter-spacing: -1px;">&euro;45+</span>
            <span style="font-size: 14px; color: rgba(0,0,0,0.3);">/seat/mo</span>
          </div>
          <p style="font-size: 14px; color: rgba(0,0,0,0.4); line-height: 1.6; margin-bottom: 16px;">
            Corporate L&amp;D departments, large academies, and organizations requiring dedicated support and custom integrations.
          </p>
          <div style="border-top: 1px solid rgba(0,0,0,0.06); padding-top: 12px; display: flex; flex-direction: column; gap: 6px;">
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; Unlimited live hours</span>
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; Unlimited storage</span>
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; Unlimited AI generations</span>
            <span style="font-size: 12px; color: rgba(0,0,0,0.35);">&#10003; SSO, audit log, dedicated support</span>
          </div>
        </div>
      </div>

      <!-- Overage pricing -->
      <div class="paper" style="border-radius: 16px; padding: 24px 28px; margin-top: 20px;">
        <p class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px;">Fair-Use Overages (Pro &amp; Team)</p>
        <div style="display: flex; gap: 32px; flex-wrap: wrap;">
          <div>
            <span style="font-size: 13px; color: rgba(0,0,0,0.5);">Extra live hours</span>
            <span class="mono" style="display: block; font-size: 14px; font-weight: 600; margin-top: 2px;">&euro;0.90 / hour</span>
          </div>
          <div>
            <span style="font-size: 13px; color: rgba(0,0,0,0.5);">Extra storage</span>
            <span class="mono" style="display: block; font-size: 14px; font-weight: 600; margin-top: 2px;">&euro;2.00 / GB / mo</span>
          </div>
          <div>
            <span style="font-size: 13px; color: rgba(0,0,0,0.5);">Extra AI generations</span>
            <span class="mono" style="display: block; font-size: 14px; font-weight: 600; margin-top: 2px;">&euro;0.03 / card</span>
          </div>
        </div>
        <p style="font-size: 12px; color: rgba(0,0,0,0.25); margin-top: 12px;">Overage revenue is accretive &mdash; marginal cost is well below overage price at scale.</p>
      </div>
    </section>

    <!-- Section 2: Unit Economics -->
    <section class="reveal" style="margin-bottom: 72px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 32px;">
        <span class="mono" style="font-size: 11px; color: rgba(0,0,0,0.25); font-weight: 600;">02</span>
        <h2 class="serif" style="font-size: 32px; letter-spacing: -1px;">Unit Economics</h2>
      </div>

      <div class="paper" style="border-radius: 20px; padding: 0; overflow: hidden;">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width: 28%;">Metric</th>
              <th>Pro (&euro;19/mo)</th>
              <th>Team (~5 seats)</th>
              <th>Enterprise (~15 seats)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="row-label">ARPU</td>
              <td>&euro;19/mo</td>
              <td>&euro;120/mo</td>
              <td>&euro;675/mo</td>
            </tr>
            <tr>
              <td class="row-label">Monthly Churn</td>
              <td>8%</td>
              <td>5%</td>
              <td>3%</td>
            </tr>
            <tr>
              <td class="row-label">Avg Customer Life</td>
              <td>12.5 mo</td>
              <td>20 mo</td>
              <td>33.3 mo</td>
            </tr>
            <tr class="row-highlight">
              <td class="row-label" style="font-weight: 700;">LTV</td>
              <td style="font-weight: 700;">&euro;237</td>
              <td style="font-weight: 700;">&euro;2,400</td>
              <td style="font-weight: 700;">&euro;22,500</td>
            </tr>
            <tr>
              <td class="row-label">Target CAC</td>
              <td>&euro;50</td>
              <td>&euro;800</td>
              <td>&euro;5,000</td>
            </tr>
            <tr class="row-highlight">
              <td class="row-label" style="font-weight: 700;">LTV / CAC</td>
              <td style="font-weight: 700; color: var(--green);">4.7x &check;</td>
              <td style="font-weight: 700; color: var(--green);">3.0x &check;</td>
              <td style="font-weight: 700; color: var(--green);">4.5x &check;</td>
            </tr>
            <tr>
              <td class="row-label">CAC Payback</td>
              <td>2.6 mo</td>
              <td>6.7 mo</td>
              <td>7.4 mo</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Section 2b: Per-Session COGS -->
    <section class="reveal" style="margin-bottom: 72px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
        <span class="mono" style="font-size: 11px; color: rgba(0,0,0,0.25); font-weight: 600;">02b</span>
        <h2 class="serif" style="font-size: 28px; letter-spacing: -1px;">Per-Session Infrastructure Cost</h2>
      </div>
      <p style="font-size: 13px; color: rgba(0,0,0,0.35); margin-bottom: 32px; margin-left: 36px; max-width: 520px; line-height: 1.6;">
        A 45-minute live session with a 30-page document generates the following variable costs. These are the real unit economics behind each copilot session.
      </p>

      <div class="paper" style="border-radius: 20px; padding: 0; overflow: hidden;">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width: 30%;">Cost Component</th>
              <th style="width: 25%;">Driver</th>
              <th style="width: 20%;">Unit Rate</th>
              <th style="width: 25%;">Per-Session Cost</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="row-label">Speech-to-Text (Deepgram)</td>
              <td>45 min live audio</td>
              <td>~&euro;0.004/min</td>
              <td>&euro;0.18</td>
            </tr>
            <tr>
              <td class="row-label">Embedding generation</td>
              <td>~120 chunks &times; query embeds</td>
              <td>~&euro;0.02/1K tokens</td>
              <td>&euro;0.04</td>
            </tr>
            <tr>
              <td class="row-label">LLM inference (cards, prompter, suggestions)</td>
              <td>~15&ndash;25 calls / session</td>
              <td>~&euro;0.03&ndash;0.06/call</td>
              <td>&euro;0.60&ndash;1.20</td>
            </tr>
            <tr>
              <td class="row-label">Vector search (pgvector)</td>
              <td>~80&ndash;120 queries</td>
              <td>Included in DB</td>
              <td>&euro;0.01</td>
            </tr>
            <tr>
              <td class="row-label">Document storage (Supabase)</td>
              <td>30-page PDF (~5 MB)</td>
              <td>&euro;0.02/GB/mo</td>
              <td>&euro;0.001</td>
            </tr>
            <tr>
              <td class="row-label">Compute &amp; orchestration</td>
              <td>Real-time pipeline uptime</td>
              <td>Estimated</td>
              <td>&euro;0.10</td>
            </tr>
            <tr class="row-highlight">
              <td class="row-label" style="font-weight: 700;">Total Variable COGS / Session</td>
              <td></td>
              <td></td>
              <td style="font-weight: 700;">&euro;0.93&ndash;1.53</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Margin callout -->
      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-top: 20px;">
        <div class="paper" style="border-radius: 14px; padding: 20px 24px; text-align: center;">
          <p class="mono" style="font-size: 10px; color: rgba(0,0,0,0.3); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;">Pro (8 sessions/mo)</p>
          <p class="serif" style="font-size: 28px; color: var(--green); letter-spacing: -1px;">&sim;36%</p>
          <p style="font-size: 11px; color: rgba(0,0,0,0.3); margin-top: 4px;">Variable-cost margin</p>
        </div>
        <div class="paper" style="border-radius: 14px; padding: 20px 24px; text-align: center;">
          <p class="mono" style="font-size: 10px; color: rgba(0,0,0,0.3); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;">Team (12 sessions/seat/mo)</p>
          <p class="serif" style="font-size: 28px; color: var(--green); letter-spacing: -1px;">&sim;50%</p>
          <p style="font-size: 11px; color: rgba(0,0,0,0.3); margin-top: 4px;">Variable-cost margin</p>
        </div>
        <div class="paper" style="border-radius: 14px; padding: 20px 24px; text-align: center;">
          <p class="mono" style="font-size: 10px; color: rgba(0,0,0,0.3); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;">Enterprise (20 sessions/seat/mo)</p>
          <p class="serif" style="font-size: 28px; color: var(--green); letter-spacing: -1px;">&sim;32%</p>
          <p style="font-size: 11px; color: rgba(0,0,0,0.3); margin-top: 4px;">Variable-cost margin</p>
        </div>
      </div>

      <p style="font-size: 12px; color: rgba(0,0,0,0.25); margin-top: 12px; font-style: italic; padding: 0 8px;">
        LLM inference is the dominant cost driver. Margins improve as we optimize prompt caching, batching, and migrate to smaller fine-tuned models for routine tasks (card generation, transition prompts).
      </p>
    </section>

    <!-- Section 3: Three-Year Revenue Projection -->
    <section class="reveal" style="margin-bottom: 72px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
        <span class="mono" style="font-size: 11px; color: rgba(0,0,0,0.25); font-weight: 600;">03</span>
        <h2 class="serif" style="font-size: 32px; letter-spacing: -1px;">Three-Year Revenue Projection</h2>
      </div>
      <p style="font-size: 13px; color: rgba(0,0,0,0.3); margin-bottom: 32px; margin-left: 28px;" class="mono">MVP launch Q3 2026</p>

      <div class="paper" style="border-radius: 20px; padding: 0; overflow: hidden;">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width: 18%;"></th>
              <th colspan="2" style="text-align: center; border-right: 1px solid rgba(0,0,0,0.06);">Pro</th>
              <th colspan="2" style="text-align: center; border-right: 1px solid rgba(0,0,0,0.06);">Team</th>
              <th colspan="2" style="text-align: center; border-right: 1px solid rgba(0,0,0,0.06);">Enterprise</th>
              <th colspan="2" style="text-align: center;">Total</th>
            </tr>
            <tr>
              <th></th>
              <th style="font-size: 10px;">Customers</th>
              <th style="font-size: 10px; border-right: 1px solid rgba(0,0,0,0.06);">MRR</th>
              <th style="font-size: 10px;">Customers</th>
              <th style="font-size: 10px; border-right: 1px solid rgba(0,0,0,0.06);">MRR</th>
              <th style="font-size: 10px;">Customers</th>
              <th style="font-size: 10px; border-right: 1px solid rgba(0,0,0,0.06);">MRR</th>
              <th style="font-size: 10px;">Customers</th>
              <th style="font-size: 10px;">MRR / ARR</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="row-label">Year 1 <span style="color: rgba(0,0,0,0.25); font-size: 11px;">(Mo 12)</span></td>
              <td>150</td>
              <td style="border-right: 1px solid rgba(0,0,0,0.04);">&euro;2,850</td>
              <td>30</td>
              <td style="border-right: 1px solid rgba(0,0,0,0.04);">&euro;3,600</td>
              <td>3</td>
              <td style="border-right: 1px solid rgba(0,0,0,0.04);">&euro;2,025</td>
              <td style="font-weight: 600;">183</td>
              <td style="font-weight: 600;">&euro;8,475 / <span style="color: var(--green);">&euro;101,700</span></td>
            </tr>
            <tr>
              <td class="row-label">Year 2 <span style="color: rgba(0,0,0,0.25); font-size: 11px;">(Mo 24)</span></td>
              <td>500</td>
              <td style="border-right: 1px solid rgba(0,0,0,0.04);">&euro;9,500</td>
              <td>120</td>
              <td style="border-right: 1px solid rgba(0,0,0,0.04);">&euro;14,400</td>
              <td>15</td>
              <td style="border-right: 1px solid rgba(0,0,0,0.04);">&euro;10,125</td>
              <td style="font-weight: 600;">635</td>
              <td style="font-weight: 600;">&euro;34,025 / <span style="color: var(--green);">&euro;408,300</span></td>
            </tr>
            <tr class="row-highlight">
              <td class="row-label" style="font-weight: 700;">Year 3 <span style="color: rgba(0,0,0,0.25); font-size: 11px;">(Mo 36)</span></td>
              <td style="font-weight: 700;">1,200</td>
              <td style="font-weight: 700; border-right: 1px solid rgba(0,0,0,0.04);">&euro;22,800</td>
              <td style="font-weight: 700;">350</td>
              <td style="font-weight: 700; border-right: 1px solid rgba(0,0,0,0.04);">&euro;42,000</td>
              <td style="font-weight: 700;">45</td>
              <td style="font-weight: 700; border-right: 1px solid rgba(0,0,0,0.04);">&euro;30,375</td>
              <td style="font-weight: 700;">1,595</td>
              <td style="font-weight: 700;">&euro;95,175 / <span style="color: var(--green);">&euro;1,142,100</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Section 4: Expense Projection -->
    <section class="reveal" style="margin-bottom: 72px;">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 32px;">
        <span class="mono" style="font-size: 11px; color: rgba(0,0,0,0.25); font-weight: 600;">04</span>
        <h2 class="serif" style="font-size: 32px; letter-spacing: -1px;">Expense Projection</h2>
      </div>

      <div class="paper" style="border-radius: 20px; padding: 0; overflow: hidden;">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width: 30%;">Category</th>
              <th>Year 1</th>
              <th>Year 2</th>
              <th>Year 3</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="row-label">Team (salaries)</td>
              <td>&euro;168,000</td>
              <td>&euro;360,000</td>
              <td>&euro;600,000</td>
            </tr>
            <tr>
              <td class="row-label">AI &amp; Infrastructure</td>
              <td>&euro;36,000</td>
              <td>&euro;84,000</td>
              <td>&euro;180,000</td>
            </tr>
            <tr>
              <td class="row-label">GTM &amp; Marketing</td>
              <td>&euro;24,000</td>
              <td>&euro;72,000</td>
              <td>&euro;144,000</td>
            </tr>
            <tr>
              <td class="row-label">Operations &amp; Legal</td>
              <td>&euro;24,000</td>
              <td>&euro;36,000</td>
              <td>&euro;48,000</td>
            </tr>
            <tr class="row-total">
              <td class="row-label" style="font-weight: 700;">Total Expenses</td>
              <td>&euro;252,000</td>
              <td>&euro;552,000</td>
              <td>&euro;972,000</td>
            </tr>
            <tr>
              <td class="row-label">Cumulative Revenue</td>
              <td>&euro;51,000</td>
              <td>&euro;256,000</td>
              <td>&euro;778,000</td>
            </tr>
            <tr class="row-highlight">
              <td class="row-label" style="font-weight: 700;">Net Cash Flow</td>
              <td style="font-weight: 700; color: var(--red);">&minus;&euro;201,000</td>
              <td style="font-weight: 700; color: var(--red);">&minus;&euro;296,000</td>
              <td style="font-weight: 700; color: var(--red);">&minus;&euro;194,000</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 10px; padding: 0 8px;">
        <div style="display: flex; align-items: center; gap: 12px;">
          <div style="width: 10px; height: 10px; border-radius: 50%; background: var(--green); flex-shrink: 0;"></div>
          <p class="mono" style="font-size: 13px; color: rgba(0,0,0,0.4);">Monthly cash-flow positive projected around <strong style="color: var(--ink);">Month 30&ndash;32</strong></p>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
          <div style="width: 10px; height: 10px; border-radius: 50%; background: var(--blue); flex-shrink: 0;"></div>
          <p class="mono" style="font-size: 13px; color: rgba(0,0,0,0.4);">Cumulative break-even by <strong style="color: var(--ink);">Month 38&ndash;40</strong></p>
        </div>
        <p style="font-size: 12px; color: rgba(0,0,0,0.25); font-style: italic; margin-top: 4px;">
