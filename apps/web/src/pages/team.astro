---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="PRETIVE — The Team" description="Meet the founding team behind PRETIVE, the real-time AI copilot for live presentations." noindex={true}>

  <Nav activePage="investors" />

  <!-- Breadcrumb -->
  <div style="padding-top: 80px; max-width: 1200px; margin: 0 auto; padding-left: 24px; padding-right: 24px;">
    <div class="reveal" style="display: flex; align-items: center; gap: 8px; padding-top: 16px;">
      <a href="/investors" class="hoverable" style="font-size: 12px; color: rgba(0,0,0,0.3); font-weight: 500; font-family: 'IBM Plex Mono', monospace; text-transform: uppercase; letter-spacing: 1px;">Investors</a>
      <span style="font-size: 12px; color: rgba(0,0,0,0.15);">/</span>
      <span class="mono" style="font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Team</span>
    </div>
  </div>


  <!-- ============================== -->
  <!-- HERO                           -->
  <!-- ============================== -->
  <section style="padding-top: 20px; padding-bottom: 60px;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative;">
      <div class="reveal">
        <div class="stamp" style="margin-bottom: 28px;">
          <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--red); display: inline-block;"></span>
          People
        </div>
        <h1 class="serif" style="font-size: clamp(3rem, 7vw, 5.5rem); line-height: 0.95; letter-spacing: -2px; margin-bottom: 24px;">
          The <span class="serif" style="font-style: italic; color: var(--red);">Team</span>
        </h1>
        <p style="font-size: 18px; color: rgba(0,0,0,0.4); max-width: 560px; line-height: 1.7; font-weight: 300;">
          A small, focused founding team with deep operational experience in live online education. We've lived the problem, and we're building the solution.
        </p>
      </div>

      <!-- Decorative annotation -->
      <div class="annotation hide-mobile" style="top: 40px; right: 60px; transform: rotate(-6deg);">
        <svg width="50" height="35" viewBox="0 0 50 35" fill="none"><path d="M45 5 Q25 2 8 28" stroke="#D94228" stroke-width="1.5" fill="none" stroke-dasharray="3 3"/><path d="M8 28 L5 22 M8 28 L14 25" stroke="#D94228" stroke-width="1.5"/></svg>
        <span style="display: block; margin-top: -4px;">built from<br>experience</span>
      </div>
    </div>
  </section>


  <!-- ============================== -->
  <!-- FOUNDING TEAM                  -->
  <!-- ============================== -->
  <section style="padding: 40px 0 80px; background: var(--paper);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
      <div class="reveal">
        <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">Founding team</span>
        <h2 class="serif" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.1; margin-top: 16px; margin-bottom: 48px; letter-spacing: -1px;">
          Two founders. <span class="serif" style="font-style: italic;">One shared conviction.</span>
        </h2>
      </div>

      <div class="founder-grid reveal-stagger" style="display: grid; grid-template-columns: 1fr 1fr; gap: 28px;">

        <!-- Bilal Senturk -->
        <div class="paper" style="border-radius: 20px; padding: 40px 36px; position: relative; transition: all 0.4s;">
          <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 24px;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--blue); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <span style="font-size: 22px; font-weight: 700; color: white; letter-spacing: 1px;">BS</span>
            </div>
            <div>
              <h3 style="font-size: 20px; font-weight: 800; letter-spacing: -0.5px;">Bilal Senturk</h3>
              <p class="mono" style="font-size: 11px; color: var(--blue); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 2px; font-weight: 600;">Head of Product & Engineering</p>
            </div>
          </div>
          <p style="font-size: 14px; color: rgba(0,0,0,0.45); line-height: 1.8; margin-bottom: 24px;">
            Owns product strategy, system architecture, AI integration, and technical product management. Years of field experience at <span class="highlight">IIENSTITU</span> shaped the design of PRETIVE as a real-time co-pilot &mdash; not another content generator.
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 6px;">
            <span class="skill-tag">System Architecture</span>
            <span class="skill-tag">AI/LLM Integration</span>
            <span class="skill-tag">Full-Stack Development</span>
            <span class="skill-tag">Real-Time Systems</span>
            <span class="skill-tag">Product Management</span>
          </div>

          <!-- Decorative annotation -->
          <div class="annotation hide-mobile" style="bottom: -30px; right: 20px; transform: rotate(4deg); font-size: 16px;">
            technical depth &uarr;
          </div>
        </div>

        <!-- Sezin Gok -->
        <div class="paper" style="border-radius: 20px; padding: 40px 36px; position: relative; transition: all 0.4s;">
          <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 24px;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background: rgba(217, 66, 40, 0.6); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <span style="font-size: 22px; font-weight: 700; color: white; letter-spacing: 1px;">SG</span>
            </div>
            <div>
              <h3 style="font-size: 20px; font-weight: 800; letter-spacing: -0.5px;">Sezin Gok</h3>
              <p class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 2px; font-weight: 600;">Growth & Marketing</p>
            </div>
          </div>
          <p style="font-size: 14px; color: rgba(0,0,0,0.45); line-height: 1.8; margin-bottom: 24px;">
            Drives commercial strategy, go-to-market, pricing logic, and distribution. Her <span class="highlight">IIENSTITU</span> background is the strongest foundation for PRETIVE's commercial hypothesis.
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 6px;">
            <span class="skill-tag">GTM Strategy</span>
            <span class="skill-tag">Pricing & Packaging</span>
            <span class="skill-tag">Enterprise Sales</span>
            <span class="skill-tag">Content Marketing</span>
            <span class="skill-tag">Community Management</span>
          </div>

          <!-- Decorative annotation -->
          <div class="annotation hide-mobile" style="bottom: -30px; left: 20px; transform: rotate(-3deg); font-size: 16px;">
            commercial engine &uarr;
          </div>
        </div>
      </div>

      <!-- Callout sticky -->
      <div class="reveal" style="margin-top: 60px; display: flex; justify-content: center;">
        <div class="sticky tape" style="max-width: 680px; transform: rotate(-1deg); font-size: 20px; padding: 24px 28px; text-align: center; line-height: 1.5;">
          Operations, product, and GTM knowledge converge in the same core. Both founders have lived through hundreds of thousands of live sessions at IIENSTITU, experiencing the problem firsthand.
        </div>
      </div>
    </div>
  </section>


  <!-- ============================== -->
  <!-- HIRING PLAN                    -->
  <!-- ============================== -->
  <section style="padding: 80px 0;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
      <div class="reveal">
        <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">Hiring plan</span>
        <h2 class="serif" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.1; margin-top: 16px; margin-bottom: 48px; letter-spacing: -1px;">
          Scaling the team <span class="serif" style="font-style: italic; color: var(--red);">with intent</span>
        </h2>
      </div>

      <div class="reveal plan-table-wrap">
        <div class="paper" style="border-radius: 20px; overflow: hidden;">
          <table class="plan-table">
            <thead>
              <tr>
                <th>Period</th>
                <th>Positions</th>
                <th>Why</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>
                  <span style="font-size: 14px;">Post pre-seed</span><br>
                  <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); letter-spacing: 1px;">MO 1&ndash;3</span>
                </td>
                <td>
                  <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 6px;">
                    <span style="display: inline-block; padding: 3px 10px; background: rgba(45, 91, 255, 0.08); border-radius: 6px; font-size: 12px; color: var(--blue); font-weight: 600;">Full-Stack Engineer &times;2</span>
                    <span style="display: inline-block; padding: 3px 10px; background: rgba(217, 66, 40, 0.08); border-radius: 6px; font-size: 12px; color: var(--red); font-weight: 600;">Applied AI/ML Engineer &times;1</span>
                  </div>
                </td>
                <td>MVP velocity: STT + LLM pipeline, Zoom/Meet integration adapters</td>
              </tr>
              <tr>
                <td>
                  <span style="font-size: 14px;">Phase 2 start</span><br>
                  <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); letter-spacing: 1px;">MO 7&ndash;9</span>
                </td>
                <td>
                  <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 6px;">
                    <span style="display: inline-block; padding: 3px 10px; background: rgba(42, 125, 79, 0.08); border-radius: 6px; font-size: 12px; color: var(--green); font-weight: 600;">Design/UX Engineer &times;1</span>
                    <span style="display: inline-block; padding: 3px 10px; background: rgba(245, 200, 66, 0.15); border-radius: 6px; font-size: 12px; color: #8B7000; font-weight: 600;">Developer Relations &times;1</span>
                  </div>
                </td>
                <td>Teacher UX optimization, marketplace listing, community</td>
              </tr>
              <tr>
                <td>
                  <span style="font-size: 14px;">Phase 3 start</span><br>
                  <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); letter-spacing: 1px;">MO 15&ndash;18</span>
                </td>
                <td>
                  <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 6px;">
                    <span style="display: inline-block; padding: 3px 10px; background: rgba(45, 91, 255, 0.08); border-radius: 6px; font-size: 12px; color: var(--blue); font-weight: 600;">Backend Engineer &times;1</span>
                    <span style="display: inline-block; padding: 3px 10px; background: rgba(217, 66, 40, 0.08); border-radius: 6px; font-size: 12px; color: var(--red); font-weight: 600;">Institutional Sales &times;1</span>
                    <span style="display: inline-block; padding: 3px 10px; background: rgba(42, 125, 79, 0.08); border-radius: 6px; font-size: 12px; color: var(--green); font-weight: 600;">Customer Success &times;1</span>
                  </div>
                </td>
                <td>Participant platform scaling, enterprise pipeline management</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================== -->
  <!-- TARGET ADVISORY BOARD          -->
  <!-- ============================== -->
  <section style="padding: 80px 0; background: var(--paper);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
      <div class="reveal">
        <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">Advisory board</span>
        <h2 class="serif" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.1; margin-top: 16px; margin-bottom: 48px; letter-spacing: -1px;">
          Target <span class="serif" style="font-style: italic; color: var(--red);">advisors</span>
        </h2>
      </div>

      <div class="advisory-grid reveal-stagger" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">

        <!-- EdTech Domain -->
        <div class="paper" style="border-radius: 20px; padding: 36px 32px; position: relative;">
          <div style="width: 44px; height: 44px; background: var(--yellow); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--ink)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a23.54 23.54 0 0 0-2.688 6.862L2.004 21h2.616l.396-4.017a23.62 23.62 0 0 1-.625-6.836m15.482 0a23.54 23.54 0 0 1 2.687 6.862L22 21h-2.616l-.396-4.017a23.62 23.62 0 0 0 .625-6.836M12 2.25l8.5 4.528v.172M12 2.25L3.5 6.778v.172M12 2.25v6.5"/></svg>
          </div>
          <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px; display: block; margin-bottom: 8px;">EdTech Domain</span>
          <h3 style="font-size: 17px; font-weight: 700; margin-bottom: 10px; letter-spacing: -0.3px;">Scaled Online Education</h3>
          <p style="font-size: 13px; color: rgba(0,0,0,0.4); line-height: 1.7;">
            Founder or C-level from a scaled online education platform &mdash; Udemy, Coursera, or Teachable ecosystem. Domain expertise in creator-led learning at scale.
          </p>
          <div class="stamp" style="position: absolute; top: 20px; right: 20px; transform: rotate(3deg); font-size: 9px; padding: 4px 10px; border-width: 2px;">
            Seeking
          </div>
        </div>

        <!-- AI/ML Technical -->
        <div class="paper" style="border-radius: 20px; padding: 36px 32px; position: relative;">
          <div style="width: 44px; height: 44px; background: rgba(45, 91, 255, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
          </div>
          <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px; display: block; margin-bottom: 8px;">AI/ML Technical</span>
          <h3 style="font-size: 17px; font-weight: 700; margin-bottom: 10px; letter-spacing: -0.3px;">Real-Time LLM Inference</h3>
          <p style="font-size: 13px; color: rgba(0,0,0,0.4); line-height: 1.7;">
            Engineer or researcher with real-time LLM inference and low-latency expertise. Deep understanding of STT pipelines, streaming architectures, and edge deployment.
          </p>
          <div class="stamp" style="position: absolute; top: 20px; right: 20px; transform: rotate(-2deg); font-size: 9px; padding: 4px 10px; border-width: 2px;">
            Seeking
          </div>
        </div>

        <!-- Enterprise SaaS Sales -->
        <div class="paper" style="border-radius: 20px; padding: 36px 32px; position: relative;">
          <div style="width: 44px; height: 44px; background: rgba(42, 125, 79, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
          </div>
          <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px; display: block; margin-bottom: 8px;">Enterprise SaaS Sales</span>
          <h3 style="font-size: 17px; font-weight: 700; margin-bottom: 10px; letter-spacing: -0.3px;">B2B Pipeline Builder</h3>
          <p style="font-size: 13px; color: rgba(0,0,0,0.4); line-height: 1.7;">
            Sales leader who has built pipeline to &euro;1M+ ARR in B2B SaaS. Understands enterprise procurement cycles, institutional selling, and land-and-expand motions.
          </p>
          <div class="stamp" style="position: absolute; top: 20px; right: 20px; transform: rotate(2deg); font-size: 9px; padding: 4px 10px; border-width: 2px;">
            Seeking
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============================== -->
  <!-- EXIT SCENARIOS                 -->
  <!-- ============================== -->
  <section style="padding: 80px 0;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
      <div class="reveal">
        <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">Exit scenarios</span>
        <h2 class="serif" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem); line-height: 1.1; margin-top: 16px; margin-bottom: 16px; letter-spacing: -1px;">
          Strategic <span class="serif" style="font-style: italic; color: var(--red);">value</span>
        </h2>
        <p style="font-size: 15px; color: rgba(0,0,0,0.35); max-width: 520px; line-height: 1.7; margin-bottom: 48px; font-weight: 300;">
          PRETIVE sits at the intersection of video conferencing, EdTech, and AI &mdash; a position that maps directly to the strategic roadmaps of several large acquirers.
        </p>
      </div>

      <div class="reveal plan-table-wrap">
        <div class="paper" style="border-radius: 20px; overflow: hidden;">
          <table class="plan-table">
            <thead>
              <tr>
                <th>Buyer</th>
                <th>Strategic Motivation</th>
                <th>PRETIVE Assets</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>
                  <span style="font-size: 15px; font-weight: 700;">Zoom</span>
                </td>
                <td>Education segment, general meeting AI expanded into education</td>
                <td>Delivery intelligence, education orchestration engine</td>
              </tr>
              <tr>
                <td>
                  <span style="font-size: 15px; font-weight: 700;">Microsoft</span>
                </td>
                <td>Teams Education + Copilot expansion into L&D</td>
                <td>Trainer Style Engine, narrative graph, education workflow data</td>
              </tr>
              <tr>
                <td>
                  <span style="font-size: 15px; font-weight: 700;">Coursera / Udemy</span>
                </td>
                <td>Live session quality improvement</td>
                <td>Two-sided platform data, participant interaction analytics</td>
              </tr>
              <tr>
                <td>
                  <span style="font-size: 15px; font-weight: 700;">Kahoot / Nearpod</span>
                </td>
                <td>Engagement layer synergy; AI delivery for quiz products</td>
                <td>Real-time decision engine, background agent, content pipeline</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Comparable M&A -->
      <div class="reveal" style="margin-top: 40px;">
        <div class="paper" style="border-radius: 16px; padding: 28px 32px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
          <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px; flex-shrink: 0;">Comparable M&A</span>
          <div style="display: flex; gap: 16px; flex-wrap: wrap; align-items: center;">
            <span style="font-size: 13px; color: rgba(0,0,0,0.5);">
              <span style="font-weight: 700; color: var(--ink);">Kahoot</span> ~$1.7B
              <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.2); margin-left: 2px;">2023</span>
            </span>
            <span style="width: 1px; height: 16px; background: rgba(0,0,0,0.08);"></span>
            <span style="font-size: 13px; color: rgba(0,0,0,0.5);">
              <span style="font-weight: 700; color: var(--ink);">Nearpod</span> ~$650M
              <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.2); margin-left: 2px;">2021</span>
            </span>
            <span style="width: 1px; height: 16px; background: rgba(0,0,0,0.08);"></span>
            <span style="font-size: 13px; color: rgba(0,0,0,0.5);">
              <span style="font-weight: 700; color: var(--ink);">Pear Deck</span>
              <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.2); margin-left: 2px;">2021</span>
            </span>
            <span style="width: 1px; height: 16px; background: rgba(0,0,0,0.08);"></span>
            <span style="font-size: 13px; color: rgba(0,0,0,0.5);">
              <span style="font-weight: 700; color: var(--ink);">Lynda.com</span> $1.5B
              <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.2); margin-left: 2px;">2015</span>
            </span>
          </div>
        </div>
      </div>

      <!-- Sticky note -->
      <div class="reveal hide-mobile" style="margin-top: 32px; display: flex; justify-content: flex-end;">
        <div class="sticky" style="transform: rotate(2deg); font-size: 16px; padding: 14px 18px; max-width: 260px;">
          Multiple exit paths across video, EdTech, and AI verticals.
        </div>
      </div>
    </div>
  </section>

  <Footer />

</BaseLayout>

<script>
  // Responsive grid fix
  function fixGrids() {
    const w = window.innerWidth;
    document.querySelectorAll('.founder-grid').forEach(g => {
      g.style.gridTemplateColumns = w < 768 ? '1fr' : '1fr 1fr';
    });
    document.querySelectorAll('.advisory-grid').forEach(g => {
      g.style.gridTemplateColumns = w < 768 ? '1fr' : 'repeat(3, 1fr)';
    });
  }
  fixGrids();
  window.addEventListener('resize', fixGrids);
</script>
