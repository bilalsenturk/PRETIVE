<script>
  // Responsive grid fix
  function fixGrids() {
    const w = window.innerWidth;
    document.querySelectorAll('.segment-grid').forEach(g => {
      g.style.gridTemplateColumns = w < 768 ? '1fr' : '1fr 1fr';
    });
    document.querySelectorAll('.stat-grid').forEach(g => {
      g.style.gridTemplateColumns = w < 768 ? '1fr' : 'repeat(3, 1fr)';
    });
    const bh = document.getElementById('beachhead-grid');
    if (bh) bh.style.gridTemplateColumns = w < 768 ? '1fr' : 'repeat(3, 1fr)';
  }
  fixGrids();
  window.addEventListener('resize', fixGrids);
</script>
