<script>
  // Progress dots
  const sections = document.querySelectorAll('[data-index]');
  const dots = document.querySelectorAll('.progress-dot');
  const progressObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const idx = e.target.dataset.index;
        dots.forEach(d => d.classList.toggle('active', d.dataset.section === idx));
      }
    });
  }, { threshold: 0.4 });
  sections.forEach(s => progressObs.observe(s));
  dots.forEach(d => d.addEventListener('click', () => {
    const s = document.querySelector(`[data-index="${d.dataset.section}"]`);
    if (s) s.scrollIntoView({ behavior: 'smooth' });
  }));

  // Responsive grid fixes
  function fixGrids() {
    const w = window.innerWidth;
    const pg = document.getElementById('problem-grid');
    const sg = document.getElementById('status-grid');
    const ig = document.getElementById('info-grid');
    const stg = document.getElementById('steps-grid');
    const mg = document.getElementById('metrics-grid');
    const fg = document.getElementById('feedback-grid');
    const og = document.getElementById('origin-grid');
    if (pg) pg.style.gridTemplateColumns = w < 768 ? '1fr' : '1fr 1fr';
    if (sg) sg.style.gridTemplateColumns = w < 768 ? '1fr' : '1fr 1fr';
    if (ig) ig.style.gridTemplateColumns = w < 768 ? '1fr' : 'repeat(3, 1fr)';
    if (stg) stg.style.gridTemplateColumns = w < 768 ? '1fr 1fr' : 'repeat(4, 1fr)';
    if (mg) mg.style.gridTemplateColumns = w < 768 ? 'repeat(2, 1fr)' : 'repeat(4, 1fr)';
    if (fg) fg.style.gridTemplateColumns = w < 768 ? '1fr' : '1fr 1fr';
    if (og) og.style.gridTemplateColumns = w < 768 ? '1fr' : '1fr 1fr';
  }
  fixGrids();
  window.addEventListener('resize', fixGrids);
</script>
