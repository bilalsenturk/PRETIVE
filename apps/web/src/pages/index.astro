---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="PRETIVE — AI Copilot for Live Online Instructors" description="Turn your knowledge into a structured, real-time teaching experience. PRETIVE listens, understands your flow, and supports your delivery while you teach.">
  <Nav activePage="home" />

  <!-- Side Progress -->
  <div class="progress-track" id="progress">
    <div class="progress-dot active" data-section="0" title="Home"></div>
    <div class="progress-dot" data-section="1" title="Problem"></div>
    <div class="progress-dot" data-section="2" title="Solution"></div>
    <div class="progress-dot" data-section="3" title="How"></div>
    <div class="progress-dot" data-section="4" title="Features"></div>
    <div class="progress-dot" data-section="5" title="Status"></div>
    <div class="progress-dot" data-section="6" title="Apply"></div>
  </div>

  <!-- ============================== -->
  <!-- HERO                            -->
  <!-- ============================== -->
  <section class="slide" data-index="0" style="padding-top: 64px;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 60px 24px; width: 100%;">
      <div style="display: grid; grid-template-columns: 1fr; gap: 40px; position: relative;">

        <div style="max-width: 900px;">
          <!-- Status stamp -->
          <div class="stamp" style="margin-bottom: 32px;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--green); display: inline-block;"></span>
            Early Access
          </div>

          <h1 class="serif" style="font-size: clamp(3rem, 8vw, 6.5rem); line-height: 0.95; letter-spacing: -2px; margin-bottom: 24px; position: relative;">
            AI copilot for<br>
            <span style="position: relative; display: inline-block;">
              <span class="scribble">live online</span>
            </span>
            <br>instructors.
          </h1>

          <p style="font-size: 18px; color: rgba(0,0,0,0.4); max-width: 540px; line-height: 1.7; margin-bottom: 8px; font-weight: 300;">
            Turn your knowledge into a structured, real-time teaching experience. PRETIVE listens, understands your flow, and supports your delivery while you teach.
          </p>
          <p style="font-size: 14px; color: rgba(0,0,0,0.25); max-width: 540px; line-height: 1.6; margin-bottom: 4px; font-weight: 400;">
            Designed specifically for live online teaching and webinar delivery.
          </p>
          <p style="font-size: 14px; color: rgba(0,0,0,0.35); max-width: 540px; line-height: 1.6; margin-bottom: 16px; font-weight: 500;">
            Validated in internal sessions. Now entering controlled pilot.
          </p>

          <!-- 3 bullets -->
          <ul style="list-style: none; margin-bottom: 36px; display: flex; flex-direction: column; gap: 8px;">
            <li style="display: flex; align-items: center; gap: 10px; font-size: 15px; color: rgba(0,0,0,0.5);">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--red); flex-shrink: 0;"></span>
              Follow your narrative in real time
            </li>
            <li style="display: flex; align-items: center; gap: 10px; font-size: 15px; color: rgba(0,0,0,0.5);">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--red); flex-shrink: 0;"></span>
              Guide transitions and timing
            </li>
            <li style="display: flex; align-items: center; gap: 10px; font-size: 15px; color: rgba(0,0,0,0.5);">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--red); flex-shrink: 0;"></span>
              Handle questions without breaking flow
            </li>
          </ul>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
            <a href="https://app.pretive.com/signup" class="hoverable" style="display: inline-flex; align-items: center; gap: 10px; padding: 16px 32px; background: var(--ink); color: white; font-size: 14px; font-weight: 600; border-radius: 50px; transition: all 0.3s; text-decoration: none;">
              Get started free
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#how-it-works" class="hoverable" style="padding: 16px 24px; font-size: 14px; color: rgba(0,0,0,0.35); font-weight: 500;">How it works &darr;</a>
          </div>
        </div>

        <!-- Floating annotation -->
        <div class="annotation hide-mobile" style="top: 20px; right: -180px; transform: rotate(-8deg);">
          <svg width="60" height="40" viewBox="0 0 60 40" fill="none"><path d="M55 5 Q30 0 10 30" stroke="#D94228" stroke-width="1.5" fill="none" stroke-dasharray="3 3"/><path d="M10 30 L6 24 M10 30 L16 27" stroke="#D94228" stroke-width="1.5"/></svg>
          <span style="display: block; margin-top: -4px;">this is the<br>key difference</span>
        </div>

        <!-- Floating Q&A card -->
        <div class="paper hide-mobile" style="position: absolute; right: 0; bottom: -20px; padding: 20px 24px; border-radius: 16px; width: 260px; transform: rotate(-1deg);">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
            <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--green);"></span>
            <span class="mono" style="font-size: 11px; color: rgba(0,0,0,0.3); text-transform: uppercase; letter-spacing: 1px;">Q&A Queue</span>
          </div>
          <p style="font-size: 13px; color: rgba(0,0,0,0.5); line-height: 1.5;">"Can you explain the integration flow?"</p>
          <span class="mono" style="font-size: 10px; color: var(--red); margin-top: 4px; display: block;">suggested: answer now</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- TRUST STRIP                     -->
  <!-- ============================== -->
  <div style="border-top: 1px solid rgba(0,0,0,0.06); border-bottom: 1px solid rgba(0,0,0,0.06); padding: 20px 0;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: center; gap: 32px; flex-wrap: wrap;">
      <p class="mono" style="font-size: 11px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px;">Built from real-world teaching experience</p>
      <span style="width: 4px; height: 4px; border-radius: 50%; background: rgba(0,0,0,0.12);"></span>
      <p class="mono" style="font-size: 11px; color: rgba(0,0,0,0.25); text-transform: uppercase; letter-spacing: 1.5px;">300,000+ learners across live sessions</p>
    </div>
  </div>

  <!-- ============================== -->
  <!-- PROBLEM                         -->
  <!-- ============================== -->
  <section class="slide" data-index="1" style="background: var(--paper);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 80px 24px; width: 100%;">
      <div class="reveal" style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;" id="problem-grid">
        <!-- Left -->
        <div>
          <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">The problem</span>
          <h2 class="serif" style="font-size: clamp(2rem, 4vw, 3.2rem); line-height: 1.1; margin-top: 16px; letter-spacing: -1px;">
            Live teaching is<br>
            <span class="serif" style="font-style: italic; color: var(--red);">cognitively</span><br>
            overloaded.
          </h2>
          <p style="font-size: 15px; color: rgba(0,0,0,0.4); line-height: 1.7; margin-top: 20px; max-width: 400px;">
            During a session, you manage what to say next, how to structure your flow, when to transition, how to handle questions, and how to keep attention &mdash; all at once.
          </p>
          <p style="font-size: 15px; color: rgba(0,0,0,0.55); line-height: 1.7; margin-top: 16px; max-width: 400px; font-weight: 500;">
            The problem is not content.<br>
            The problem is <span class="highlight-red">live delivery.</span>
          </p>
        </div>

        <!-- Right: Problem cards -->
        <div style="display: flex; flex-direction: column; gap: 16px;">
          <div class="paper" style="padding: 24px 28px; border-radius: 16px; position: relative;">
            <div class="annotation hide-mobile" style="top: -20px; left: -60px; transform: rotate(-12deg); font-size: 16px;">
              <svg width="30" height="20" viewBox="0 0 30 20" fill="none"><path d="M2 18 Q15 5 28 8" stroke="#D94228" stroke-width="1.2" fill="none"/><path d="M28 8 L24 4 M28 8 L25 13" stroke="#D94228" stroke-width="1.2"/></svg>
              <span>this happens<br>every time</span>
            </div>
            <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.2); text-transform: uppercase; letter-spacing: 1px;">01</span>
            <h3 style="font-size: 16px; font-weight: 700; margin: 4px 0 6px;">What to say next</h3>
            <p style="font-size: 13px; color: rgba(0,0,0,0.35); line-height: 1.6;">Structuring your flow while speaking. Same content for 15 vs 60 minutes means complete rework.</p>
          </div>

          <div class="paper" style="padding: 24px 28px; border-radius: 16px; transform: rotate(0.5deg);">
            <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.2); text-transform: uppercase; letter-spacing: 1px;">02</span>
            <h3 style="font-size: 16px; font-weight: 700; margin: 4px 0 6px;">When to transition</h3>
            <p style="font-size: 13px; color: rgba(0,0,0,0.35); line-height: 1.6;">Pacing drifts. You run out of time or rush through the most important parts.</p>
          </div>

          <div class="paper" style="padding: 24px 28px; border-radius: 16px; transform: rotate(-0.3deg);">
            <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.2); text-transform: uppercase; letter-spacing: 1px;">03</span>
            <h3 style="font-size: 16px; font-weight: 700; margin: 4px 0 6px;">How to handle questions</h3>
            <p style="font-size: 13px; color: rgba(0,0,0,0.35); line-height: 1.6;">Questions break your narrative thread. Getting back on track is painful.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- SOLUTION                        -->
  <!-- ============================== -->
  <section class="slide" data-index="2" style="min-height: auto; padding: 100px 0;">
    <div style="max-width: 800px; margin: 0 auto; padding: 0 24px; text-align: center;">
      <div class="reveal">
        <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">The solution</span>
        <h2 class="serif" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1; margin-top: 16px; margin-bottom: 24px; letter-spacing: -1px;">
          A real-time<br><span class="serif" style="font-style: italic; color: var(--red);">delivery layer.</span>
        </h2>
        <p style="font-size: 18px; color: rgba(0,0,0,0.4); max-width: 520px; margin: 0 auto 20px; line-height: 1.7; font-weight: 300;">
          You speak. PRETIVE understands your context and supports your delivery.
        </p>
        <div style="display: flex; justify-content: center; gap: 40px; margin-top: 32px;">
          <div style="text-align: center;">
            <span class="mono" style="font-size: 11px; color: rgba(0,0,0,0.2); text-transform: uppercase; letter-spacing: 1px;">Not before.</span>
          </div>
          <div style="text-align: center;">
            <span class="mono" style="font-size: 11px; color: rgba(0,0,0,0.2); text-transform: uppercase; letter-spacing: 1px;">Not after.</span>
          </div>
          <div style="text-align: center;">
            <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 1px; font-weight: 700;">During the session.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- HOW IT WORKS                    -->
  <!-- ============================== -->
  <section id="how-it-works" class="slide" data-index="3" style="min-height: auto; padding: 100px 0; background: var(--paper);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; width: 100%;">
      <div class="reveal">
        <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">How it works</span>
        <h2 class="serif" style="font-size: clamp(2rem, 4vw, 3rem); line-height: 1.1; margin-top: 16px; margin-bottom: 60px; letter-spacing: -1px;">Four steps.</h2>
      </div>

      <div class="reveal" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;" id="steps-grid">
        <div style="position: relative;">
          <span class="serif" style="font-size: 100px; line-height: 1; color: rgba(0,0,0,0.03); position: absolute; top: -16px; left: -6px; pointer-events: none;">1</span>
          <div style="position: relative; padding-top: 36px;">
            <div style="width: 48px; height: 48px; background: var(--yellow); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--ink)" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
            </div>
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 8px;">Upload your content</h3>
            <p style="font-size: 14px; color: rgba(0,0,0,0.35); line-height: 1.7;">Slides, notes, or documents.</p>
          </div>
        </div>

        <div style="position: relative;">
          <span class="serif" style="font-size: 100px; line-height: 1; color: rgba(0,0,0,0.03); position: absolute; top: -16px; left: -6px; pointer-events: none;">2</span>
          <div style="position: relative; padding-top: 36px;">
            <div style="width: 48px; height: 48px; background: rgba(45,91,255,0.08); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            </div>
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 8px;">PRETIVE prepares a flow</h3>
            <p style="font-size: 14px; color: rgba(0,0,0,0.35); line-height: 1.7;">Topics, transitions, support elements &mdash; structured automatically.</p>
          </div>
        </div>

        <div style="position: relative;">
          <span class="serif" style="font-size: 100px; line-height: 1; color: rgba(0,0,0,0.03); position: absolute; top: -16px; left: -6px; pointer-events: none;">3</span>
          <div style="position: relative; padding-top: 36px;">
            <div style="width: 48px; height: 48px; background: rgba(217,66,40,0.08); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
            </div>
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 8px;">Start your session</h3>
            <p style="font-size: 14px; color: rgba(0,0,0,0.35); line-height: 1.7;">PRETIVE follows your speech in real time.</p>
          </div>
        </div>

        <div style="position: relative;">
          <span class="serif" style="font-size: 100px; line-height: 1; color: rgba(0,0,0,0.03); position: absolute; top: -16px; left: -6px; pointer-events: none;">4</span>
          <div style="position: relative; padding-top: 36px;">
            <div style="width: 48px; height: 48px; background: rgba(42,125,79,0.08); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
            </div>
            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 8px;">Get live support</h3>
            <p style="font-size: 14px; color: rgba(0,0,0,0.35); line-height: 1.7;">Transition suggestions, context cards, timing guidance, Q&A assistance.</p>
          </div>
        </div>
      </div>

      <!-- Trust note -->
      <div class="reveal" style="margin-top: 40px; max-width: 560px;">
        <div style="padding: 16px 24px; border-left: 3px solid var(--green); background: rgba(42,125,79,0.03); border-radius: 0 12px 12px 0;">
          <p style="font-size: 13px; color: rgba(0,0,0,0.45); line-height: 1.6; margin: 0;">
            <strong style="color: rgba(0,0,0,0.6);">Controlled AI, not generative chaos.</strong> PRETIVE does not generate content blindly. It works on structured content you provide and real-time context from your speech. No uncontrolled generation. All AI outputs are clearly labeled.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== -->
  <!-- CORE FEATURES                   -->
  <!-- ============================== -->
  <section id="features" class="slide" data-index="4" style="min-height: auto; padding: 100px 0;">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; width: 100%;">
      <div class="reveal">
        <span class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">Core features</span>
        <h2 class="serif" style="font-size: clamp(2rem, 4vw, 3.2rem); line-height: 1.1; margin-top: 16px; margin-bottom: 60px; letter-spacing: -1px; max-width: 600px;">
          Not a teleprompter.<br>Not a slide maker.<br>
          <span class="serif" style="font-style: italic; color: var(--red);">Live Delivery Intelligence.</span>
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 16px;" class="reveal">
        <!-- Row 1 -->
        <div class="paper bento-hover" style="grid-column: span 7; padding: 36px; border-radius: 20px; position: relative; transition: all 0.4s;">
          <div style="display: flex; align-items: flex-start; gap: 20px;">
            <div style="width: 48px; height: 48px; background: var(--yellow); border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--ink)" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            </div>
            <div>
              <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 6px;">Real-time narrative tracking</h3>
              <p style="font-size: 14px; color: rgba(0,0,0,0.4); line-height: 1.7; max-width: 400px;">Understand where you are in your content at every moment. PRETIVE maps your speech to your source material and tracks your position within a structured narrative graph.</p>
            </div>
          </div>
        </div>

        <div class="paper" style="grid-column: span 5; padding: 36px; border-radius: 20px; background: var(--ink); color: white; transition: all 0.4s;">
          <div style="width: 48px; height: 48px; background: rgba(255,255,255,0.1); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
          </div>
          <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 6px;">Semantic prompting</h3>
          <p style="font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.7;">Know what to say next without scripts. Tracks <em>meaning</em>, not words. Pauses when you pause. Tolerates improvisation. Guides you back if you skip ahead.</p>
        </div>

        <!-- Row 2 -->
        <div class="paper" style="grid-column: span 4; padding: 32px; border-radius: 20px; transition: all 0.4s;">
          <div style="width: 44px; height: 44px; background: rgba(42,125,79,0.08); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
          </div>
          <h3 style="font-size: 15px; font-weight: 700; margin-bottom: 4px;">Context cards</h3>
          <p style="font-size: 13px; color: rgba(0,0,0,0.35); line-height: 1.6;">Show summaries, comparisons, and key ideas &mdash; grounded in your own documents.</p>
        </div>

        <div class="paper" style="grid-column: span 4; padding: 32px; border-radius: 20px; background: rgba(217,66,40,0.03); border-color: rgba(217,66,40,0.08); transition: all 0.4s;">
          <div style="width: 44px; height: 44px; background: rgba(217,66,40,0.08); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px;">
