---
interface Props {
  showInvestorLinks?: boolean;
}

const { showInvestorLinks = false } = Astro.props;
---

<footer style="padding: 32px 0; border-top: 1px solid rgba(0,0,0,0.06);">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
    <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: {showInvestorLinks ? '20px' : '0'};">
      <div style="display: flex; align-items: center; gap: 10px;">
        <img src="/logo.jpg" alt="PRETIVE" style="width: 24px; height: 24px; border-radius: 8px; object-fit: cover;">
        <span style="font-size: 13px; font-weight: 700;">PRETIVE</span>
      </div>
      <div style="display: flex; gap: 24px;">
        <a href="/#features" style="font-size: 12px; color: rgba(0,0,0,0.3);">Features</a>
        <a href="/#pricing" style="font-size: 12px; color: rgba(0,0,0,0.3);">Pricing</a>
        <a href="/investors" style="font-size: 12px; color: rgba(0,0,0,0.3);">Investors</a>
        <a href="mailto:hello@pretive.com" style="font-size: 12px; color: rgba(0,0,0,0.3);">Contact</a>
      </div>
      <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.15);">&copy; 2026 PRETIVE</span>
    </div>
    {showInvestorLinks && (
      <div style="display: flex; gap: 20px; flex-wrap: wrap; padding-top: 16px; border-top: 1px solid rgba(0,0,0,0.04);">
        <span class="mono" style="font-size: 10px; color: rgba(0,0,0,0.2); text-transform: uppercase; letter-spacing: 1px; margin-right: 8px;">Investor pages:</span>
        <a href="/market" style="font-size: 12px; color: rgba(0,0,0,0.3);">Market</a>
        <a href="/financials" style="font-size: 12px; color: rgba(0,0,0,0.3);">Financials</a>
        <a href="/roadmap" style="font-size: 12px; color: rgba(0,0,0,0.3);">Roadmap</a>
        <a href="/team" style="font-size: 12px; color: rgba(0,0,0,0.3);">Team</a>
      </div>
    )}
  </div>
</footer>
