---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="PRETIVE — Product Roadmap" description="Pretive's 5-phase product roadmap: from core MVP to full platform layer. See how we're building real-time presentation intelligence.">

  <Nav activePage="investors" />

  <!-- Breadcrumb -->
  <div style="max-width: 1200px; margin: 0 auto; padding: 84px 24px 0;">
    <div style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: rgba(0,0,0,0.35);">
      <a href="/investors" class="hoverable" style="color: rgba(0,0,0,0.35); transition: color 0.2s;">Investors</a>
      <span>/</span>
      <span style="color: rgba(0,0,0,0.6); font-weight: 500;">Product Roadmap</span>
    </div>
  </div>

  <!-- ============================== -->
  <!-- HERO                            -->
  <!-- ============================== -->
  <section style="padding: 48px 24px 80px; max-width: 1200px; margin: 0 auto;">
    <div class="reveal" style="max-width: 740px;">
      <div class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 16px;">Product Roadmap</div>
      <h1 class="serif" style="font-size: clamp(2.4rem, 6vw, 4.5rem); line-height: 1.0; letter-spacing: -1.5px; margin-bottom: 20px;">
        Five phases from <span class="highlight">MVP</span> to <span class="highlight-red">platform</span>
      </h1>
      <p style="font-size: 17px; color: rgba(0,0,0,0.45); max-width: 560px; line-height: 1.7; font-weight: 300;">
        A disciplined 36-month product plan that takes Pretive from a single-user copilot to a full presentation intelligence platform, with clear milestones and measurable KPIs at every stage.
      </p>
    </div>
  </section>

  <!-- ============================== -->
  <!-- TIMELINE                        -->
  <!-- ============================== -->
  <section style="max-width: 1200px; margin: 0 auto; padding: 0 24px 100px;">
    <div class="timeline">

      <!-- PHASE 1 -->
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="paper" style="border-radius: 20px; padding: 36px 32px; position: relative;">
          <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 20px;">
            <span class="phase-badge" style="background: rgba(217,66,40,0.08); color: var(--red);">Phase 1</span>
            <span style="font-size: 13px; color: rgba(0,0,0,0.3); font-weight: 500;">Month 0 &ndash; 12</span>
          </div>
          <h3 class="serif" style="font-size: 28px; margin-bottom: 8px; letter-spacing: -0.5px;">Core MVP</h3>
          <p style="font-size: 14px; color: rgba(0,0,0,0.5); line-height: 1.8; margin-bottom: 24px; max-width: 640px;">
            Build the foundational intelligence loop. Content ingestion from Drive and OneDrive feeds a narrative engine that generates pre-session drafts. A semantic prompter drives live speech tracking while basic screen intelligence and real-time fact-checking ensure accuracy. Every session closes with an automated summary. Ship Zoom and Google Meet integrations to reach users where they already present.
          </p>

          <div class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Key deliverables</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px;">
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Content ingestion</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Pre-session draft generation</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Narrative engine</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Semantic prompter</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Live speech tracking</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Basic screen intelligence</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Basic fact-check</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Session summary</span>
          </div>

          <div class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Integrations</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px;">
            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: rgba(45,91,255,0.06); border-radius: 8px; font-size: 12px; color: var(--blue); font-weight: 500;">Zoom</span>
            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: rgba(42,125,79,0.06); border-radius: 8px; font-size: 12px; color: var(--green); font-weight: 500;">Google Meet</span>
            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.45);">Google Drive</span>
            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.45);">OneDrive</span>
          </div>

          <div style="border-top: 1px solid rgba(0,0,0,0.05); padding-top: 16px;">
            <div class="mono" style="font-size: 10px; color: var(--green); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Target KPIs</div>
            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
              <span class="kpi-pill"><span class="kpi-dot"></span>150 paying accounts</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>&euro;8K MRR</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Weekly active 60%+</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Zoom + Meet marketplace approval</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>NPS &ge; 40</span>
            </div>
          </div>
        </div>
      </div>

      <!-- PHASE 2 -->
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="paper" style="border-radius: 20px; padding: 36px 32px; position: relative;">
          <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 20px;">
            <span class="phase-badge" style="background: rgba(45,91,255,0.08); color: var(--blue);">Phase 2</span>
            <span style="font-size: 13px; color: rgba(0,0,0,0.3); font-weight: 500;">Month 13 &ndash; 18</span>
          </div>
          <h3 class="serif" style="font-size: 28px; margin-bottom: 8px; letter-spacing: -0.5px;">Controlled Live Augmentation</h3>
          <p style="font-size: 14px; color: rgba(0,0,0,0.5); line-height: 1.8; margin-bottom: 24px; max-width: 640px;">
            Graduate from passive guidance to active augmentation. An autonomous decision engine and background agent system work together to surface comparison cards, media additions, and real-time overlays without breaking the presenter's flow. A question engine and command-based expansion give presenters superpowers during live Q&A.
          </p>

          <div class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Key deliverables</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px;">
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Autonomous decision engine</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Background agent system</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Question engine</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Command-based expansion</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Comparison cards</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Media additions</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Online overlay</span>
          </div>

          <div class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Integrations</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px;">
            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: rgba(45,91,255,0.06); border-radius: 8px; font-size: 12px; color: var(--blue); font-weight: 500;">Microsoft Teams</span>
            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: rgba(42,125,79,0.06); border-radius: 8px; font-size: 12px; color: var(--green); font-weight: 500;">Webex</span>
          </div>

          <div style="border-top: 1px solid rgba(0,0,0,0.05); padding-top: 16px;">
            <div class="mono" style="font-size: 10px; color: var(--green); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Target KPIs</div>
            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
              <span class="kpi-pill"><span class="kpi-dot"></span>400 accounts</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>&euro;20K MRR</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Teams integration</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Monthly churn &lt; 6%</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>10+ enterprise pilots</span>
            </div>
          </div>
        </div>
      </div>

      <!-- PHASE 3 -->
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="paper" style="border-radius: 20px; padding: 36px 32px; position: relative;">
          <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 20px;">
            <span class="phase-badge" style="background: rgba(42,125,79,0.08); color: var(--green);">Phase 3</span>
            <span style="font-size: 13px; color: rgba(0,0,0,0.3); font-weight: 500;">Month 19 &ndash; 24</span>
          </div>
          <h3 class="serif" style="font-size: 28px; margin-bottom: 8px; letter-spacing: -0.5px;">Participant Platform</h3>
          <p style="font-size: 14px; color: rgba(0,0,0,0.5); line-height: 1.8; margin-bottom: 24px; max-width: 640px;">
            Flip the model from single-user to multi-sided. Each participant gets their own AI agent, interactive quizzes and surveys, and personal notes that persist after the session ends. For organizations, a corporate workspace with admin panel and interaction analytics turns presentation data into actionable insight. LMS integrations via LTI 1.3 and webinar platform connections expand distribution.
          </p>

          <div class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Key deliverables</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px;">
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Participant agent</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Interactive quiz / survey</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Personal notes</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Corporate workspace</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Admin panel</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Interaction analytics</span>
          </div>

          <div class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Integrations</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px;">
            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: rgba(45,91,255,0.06); border-radius: 8px; font-size: 12px; color: var(--blue); font-weight: 500;">LMS (LTI 1.3)</span>
            <span style="display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: rgba(42,125,79,0.06); border-radius: 8px; font-size: 12px; color: var(--green); font-weight: 500;">Webinar platforms</span>
          </div>

          <div style="border-top: 1px solid rgba(0,0,0,0.05); padding-top: 16px;">
            <div class="mono" style="font-size: 10px; color: var(--green); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Target KPIs</div>
            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
              <span class="kpi-pill"><span class="kpi-dot"></span>800 accounts</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>&euro;50K MRR</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>5,000+ active participants</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>2+ LMS integrations</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Participant viral coefficient &ge; 1.1</span>
            </div>
          </div>
        </div>
      </div>

      <!-- PHASE 4 -->
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="paper" style="border-radius: 20px; padding: 36px 32px; position: relative;">
          <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 20px;">
            <span class="phase-badge" style="background: rgba(245,200,66,0.15); color: #8B7000;">Phase 4</span>
            <span style="font-size: 13px; color: rgba(0,0,0,0.3); font-weight: 500;">Month 25 &ndash; 30</span>
          </div>
          <h3 class="serif" style="font-size: 28px; margin-bottom: 8px; letter-spacing: -0.5px;">Adaptive Intelligence</h3>
          <p style="font-size: 14px; color: rgba(0,0,0,0.5); line-height: 1.8; margin-bottom: 24px; max-width: 640px;">
            Move from generic assistance to personalized intelligence. The system learns each presenter's teaching style, autonomously manages presentation flow, and builds team-wide memory across sessions. A complete audit log and advanced analytics package makes Pretive enterprise-ready for regulated industries.
          </p>

          <div class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Key deliverables</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px;">
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Teacher style learning</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Autonomous presentation mgmt</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Team memory</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Audit log</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Advanced analytics</span>
          </div>

          <div style="border-top: 1px solid rgba(0,0,0,0.05); padding-top: 16px;">
            <div class="mono" style="font-size: 10px; color: var(--green); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Target KPIs</div>
            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
              <span class="kpi-pill"><span class="kpi-dot"></span>1,200 accounts</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>&euro;80K MRR</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>SOC 2 Type II</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Enterprise churn &lt; 3%</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Net Revenue Retention &ge; 110%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- PHASE 5 -->
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="paper" style="border-radius: 20px; padding: 36px 32px; position: relative;">
          <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 20px;">
            <span class="phase-badge" style="background: rgba(0,0,0,0.06); color: var(--ink);">Phase 5</span>
            <span style="font-size: 13px; color: rgba(0,0,0,0.3); font-weight: 500;">Month 31 &ndash; 36+</span>
          </div>
          <h3 class="serif" style="font-size: 28px; margin-bottom: 8px; letter-spacing: -0.5px;">Platform Layer</h3>
          <p style="font-size: 14px; color: rgba(0,0,0,0.5); line-height: 1.8; margin-bottom: 24px; max-width: 640px;">
            Open the engine to the ecosystem. A public API and SDK let third parties build on Pretive's real-time intelligence. Deeper enterprise controls, whitelabel options, and live delivery infrastructure transform the product from a standalone tool into presentation infrastructure that other products are built on top of.
          </p>

          <div class="mono" style="font-size: 10px; color: var(--red); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Key deliverables</div>
          <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px;">
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">API / SDK</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Third-party integrations</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Deeper enterprise controls</span>
            <span style="display: inline-block; padding: 5px 12px; background: rgba(0,0,0,0.03); border-radius: 8px; font-size: 12px; color: rgba(0,0,0,0.55);">Live delivery infrastructure</span>
          </div>

          <div style="border-top: 1px solid rgba(0,0,0,0.05); padding-top: 16px;">
            <div class="mono" style="font-size: 10px; color: var(--green); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;">Target KPIs</div>
            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
              <span class="kpi-pill"><span class="kpi-dot"></span>&euro;1M+ ARR</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>20+ API customers</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Monthly positive cash flow</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>Gross margin 85%+</span>
              <span class="kpi-pill"><span class="kpi-dot"></span>3+ whitelabel deals</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ============================== -->
  <!-- FIRST 90 DAYS                   -->
  <!-- ============================== -->
  <section style="max-width: 1200px; margin: 0 auto; padding: 0 24px 100px;">
    <div class="reveal" style="margin-bottom: 48px;">
      <div class="mono" style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 16px;">Technical Validation</div>
      <h2 class="serif" style="font-size: clamp(1.8rem, 4vw, 3rem); letter-spacing: -1px; margin-bottom: 12px;">The first 90 days</h2>
      <p style="font-size: 15px; color: rgba(0,0,0,0.4); max-width: 480px; line-height: 1.7; font-weight: 300;">
        Three focused sprints to validate the hardest technical assumptions before writing a single line of product code.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">

      <!-- Day 0-30 -->
      <div class="paper validation-card reveal" style="border-radius: 20px; padding: 32px 28px;">
        <span class="day-badge" style="background: rgba(217,66,40,0.08); color: var(--red); margin-bottom: 16px;">Day 0 &ndash; 30</span>
        <h4 style="font-size: 17px; font-weight: 700; margin: 16px 0 8px; letter-spacing: -0.3px;">Speech-to-Graph Matching PoC</h4>
        <p style="font-size: 13px; color: rgba(0,0,0,0.45); line-height: 1.7; margin-bottom: 20px;">
          Prove that spoken words can be mapped to presentation graph nodes in real time. This is the foundational capability every other feature depends on.
        </p>
        <div style="display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: rgba(42,125,79,0.05); border-radius: 10px;">
          <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--green); flex-shrink: 0;"></span>
          <span style="font-size: 12px; color: var(--green); font-weight: 600;">Target: 85%+ position accuracy</span>
        </div>
      </div>

      <!-- Day 30-60 -->
      <div class="paper validation-card reveal" style="border-radius: 20px; padding: 32px 28px;">
        <span class="day-badge" style="background: rgba(45,91,255,0.08); color: var(--blue); margin-bottom: 16px;">Day 30 &ndash; 60</span>
        <h4 style="font-size: 17px; font-weight: 700; margin: 16px 0 8px; letter-spacing: -0.3px;">Live Pipeline on Zoom SDK</h4>
        <p style="font-size: 13px; color: rgba(0,0,0,0.45); line-height: 1.7; margin-bottom: 20px;">
