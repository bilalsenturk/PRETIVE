---
interface Props {
  activePage?: string;
  topOffset?: string;
}

const { activePage = 'home', topOffset } = Astro.props;

const navLinks = [
  { href: '/#features', label: 'Features', key: 'features' },
  { href: '/#compare', label: 'Compare', key: 'compare' },
  { href: '/#pricing', label: 'Pricing', key: 'pricing' },
  { href: '/investors', label: 'Investors', key: 'investors' },
];
---

<nav id="nav" style={topOffset ? `top: ${topOffset}` : undefined}>
  <div style="max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 64px;">
    <a href="/" style="display: flex; align-items: center; gap: 10px;" class="hoverable">
      <img src="/logo.jpg" alt="Pretive" style="width: 32px; height: 32px; border-radius: 10px; object-fit: cover;">
      <span style="font-size: 15px; font-weight: 700; letter-spacing: -0.5px;">pretive</span>
    </a>
    <div style="display: flex; align-items: center; gap: 32px;" class="hide-mobile">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="hoverable"
          style={`font-size: 13px; font-weight: ${activePage === link.key ? '600' : '500'}; color: ${activePage === link.key ? 'var(--red)' : 'rgba(0,0,0,0.4)'};`}
        >
          {link.label}
        </a>
      ))}
      <a href="/#waitlist" class="hoverable" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; background: var(--ink); color: white; font-size: 13px; font-weight: 600; border-radius: 50px;">
        <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--red);"></span>
        Early access
      </a>
    </div>
  </div>
</nav>
